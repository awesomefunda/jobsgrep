# ─── Core ───────────────────────────────────────────────────────────────────
# Deployment mode: LOCAL | PRIVATE | PUBLIC
JOBSGREP_MODE=LOCAL

# Required for NL query parsing and job scoring
GROQ_API_KEY=gsk_xxx

# Recommended: primary scorer (1500 req/day free tier)
GEMINI_API_KEY=

# ─── Auth (required for PRIVATE and PUBLIC modes) ────────────────────────────
# PRIVATE mode: shared bearer token
JOBSGREP_ACCESS_TOKEN=

# PUBLIC mode: optional OAuth (leave blank to disable)
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=

# ─── Contact email for User-Agent header (legal best practice) ───────────────
JOBSGREP_CONTACT_EMAIL=your-email@example.com

# ─── Source control ──────────────────────────────────────────────────────────
# Force-enable scraping in non-LOCAL modes (use with extreme caution)
ALLOW_SCRAPE=false

# Minimum fit score to include in report (0.0 - 1.0)
MIN_FIT_SCORE=0.7

# USAJobs API key (free at developer.usajobs.gov)
USAJOBS_API_KEY=

# ─── Rate limits ─────────────────────────────────────────────────────────────
# Searches per hour per user/IP
SEARCH_RATE_LIMIT=10

# API calls per minute per source
SOURCE_RATE_LIMIT=60

# ─── Infrastructure ──────────────────────────────────────────────────────────
# Server bind address and port
HOST=0.0.0.0
PORT=8080

# Log level: DEBUG | INFO | WARNING | ERROR (empty = DEBUG in LOCAL, INFO otherwise)
LOG_LEVEL=

# Optional Redis for rate limiting in PUBLIC mode (falls back to in-memory)
REDIS_URL=

# Cache TTL for job listings in seconds (0 = disabled, never cache in PUBLIC mode)
CACHE_TTL=3600

# ─── Data retention (PUBLIC mode) ────────────────────────────────────────────
# Auto-delete Excel files after N seconds post-download (PUBLIC mode only)
PUBLIC_FILE_TTL=3600

# ─── Background prefetch (PRIVATE/PUBLIC modes) ───────────────────────────────
# Comma-separated list of queries to pre-warm on startup (empty = built-in defaults)
PREFETCH_QUERIES=
# How often to repeat the prefetch cycle (in hours)
PREFETCH_INTERVAL_HOURS=6
# Run prefetch on server startup
PREFETCH_ON_STARTUP=true

# ─── Local push auth ─────────────────────────────────────────────────────────
# Token required when pushing jobs from local → prod via `jobsgrep push`
# Defaults to JOBSGREP_ACCESS_TOKEN if not set separately
PUSH_TOKEN=
